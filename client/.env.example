# ============================================================
#  NoteMind Client - Environment Configuration
#  Vite Frontend Environment Variables
#
#  Copy this file to client/.env for local development
# ============================================================

# ────────────────────────────────────────────────────────
#  🌐 API CONFIGURATION
# ────────────────────────────────────────────────────────
# API Base URL (optional - auto-detected by default)
# Leave empty for auto-detection based on environment
# 
# Development: Automatically uses /api (proxied by Vite to localhost:3001)
# Production: Automatically uses https://api.yourdomain.com
# 
# VITE_API_URL=


# ────────────────────────────────────────────────────────
#  🔧 DEVELOPMENT SETTINGS
# ────────────────────────────────────────────────────────
# Port for Vite dev server (default: 5173)
# VITE_PORT=5173

# Enable/disable features in development
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_ERROR_TRACKING=false

# ────────────────────────────────────────────────────────
#  📝 NOTES
# ────────────────────────────────────────────────────────
# ⚠️  Only VITE_ prefixed variables are exposed to client code
# ⚠️  Never store sensitive secrets in client env vars (they're public)
# 🔄 Changes require dev server restart (npm run dev)
# 🛡️ PRODUCTION: Keep client env free of sensitive secrets
# 📦 Build process: Variables are embedded in bundle at build time

# ────────────────────────────────────────────────────────
#  🚀 PRODUCTION BUILD
# ────────────────────────────────────────────────────────
# For production builds, keep VITE_ vars limited to non-sensitive values
