# ============================================================
#  NoteMind - AI-Powered Study Assistant
#  Environment Configuration Template
#
#  Copy this file to server/.env and fill in actual values
# ============================================================

# ────────────────────────────────────────────────────────
#  🚀 SERVER CONFIGURATION
# ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ────────────────────────────────────────────────────────
#  🤖 AI MODEL CONFIGURATION  
#
#  Option A: DashScope (Recommended - Cloud-based)
#  Free tier: 1 million tokens/month
# ────────────────────────────────────────────────────────
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-your-dashscope-api-key-here
QWEN_MODEL=qwen3-max

# ────────────────────────────────────────────────────────
#  🤖 OLLAMA (Local/Free Alternative)
#  
#  To use Ollama instead:
#  1. Install Ollama: https://ollama.com
#  2. Pull model: ollama pull qwen3
#  3. Uncomment lines below
#  4. Comment out DashScope configuration above
# ────────────────────────────────────────────────────────
# QWEN_API_BASE_URL=http://localhost:11434/v1
# QWEN_API_KEY=ollama
# QWEN_MODEL=qwen3

# ────────────────────────────────────────────────────────
#  🔐 AUTHENTICATION & SECURITY (REQUIRED FOR PRODUCTION)
# ────────────────────────────────────────────────────────

# JWT secret for signing tokens (REQUIRED - min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ CRITICAL: Server will NOT start without this in production
JWT_SECRET=your-secure-jwt-secret-key-min-32-characters-long


# Cloudflare Turnstile Secret (REQUIRED for production bot protection)
# Get from: https://dash.cloudflare.com/profile/api-tokens
# ⚠️ CRITICAL: Server will NOT start in production without this
# Development: Can be skipped if NODE_ENV=development
TURNSTILE_SECRET=0x4AAAAAACCkE-YqorZdo6vjcjprTWSC8lM

# CORS Allowed Origins (REQUIRED - comma-separated list)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ────────────────────────────────────────────────────────
#  💾 DATABASE CONFIGURATION
# ────────────────────────────────────────────────────────
DATABASE_PATH=./data/notemind.db

# ────────────────────────────────────────────────────────
#  📋 PLAN QUOTAS & RATE LIMITING
# ────────────────────────────────────────────────────────
# Free plan daily upload limit
GUEST_DAILY_LIMIT=5

# Free plan chat message limit per document
GUEST_CHAT_LIMIT=10

# ────────────────────────────────────────────────────────
#  📧 EMAIL CONFIGURATION (Optional)
# ────────────────────────────────────────────────────────
# Common SMTP providers:
#
# Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password (not regular password!)
#
# Titan Email:
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=587
# SMTP_USER=your-email@yourdomain.com
# SMTP_PASS=your-titan-password
#
# Resend (Modern Alternative):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key
# ────────────────────────────────────────────────────────
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=NoteMind

# ────────────────────────────────────────────────────────
#  🌐 CORS & DEPLOYMENT
# ────────────────────────────────────────────────────────
# Production domain (without protocol)
# Used for CORS and subdomain configuration
DOMAIN=yourdomain.com

# Frontend URL for CORS configuration
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# API domain for share links
# Development: http://localhost:3001
# Production: https://api.yourdomain.com
API_DOMAIN=http://localhost:3001

# ────────────────────────────────────────────────────────
#  📊 LOGGING & MONITORING
# ────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ────────────────────────────────────────────────────────
#  🔍 SECURITY & ADMIN
# ────────────────────────────────────────────────────────
# Admin user email (created on first run)
ADMIN_EMAIL=admin@notemind.app
ADMIN_PASSWORD=ChangeMe123!

# API rate limit (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────
#  ⚙️ ADVANCED options
# ────────────────────────────────────────────────────────
# Max upload file size
MAX_FILE_SIZE=52428800  # 50MB in bytes

# Session timeout (minutes)
SESSION_TIMEOUT=1440  # 24 hours


# ────────────────────────────────────────────────────────
#  📝 NOTES
# ────────────────────────────────────────────────────────
# ✅ REQUIRED for ALL environments:
#    - JWT_SECRET (min 32 chars)
#    - ALLOWED_ORIGINS
#
# ✅ REQUIRED for PRODUCTION only:
#    - TURNSTILE_SECRET
#    - NODE_ENV=production
#
# ⚠️  SECURITY: Never commit .env file to Git (already in .gitignore)
# 🔄 UPDATES: When deploying, update server/.env (not this example file)
# 🛡️ PRODUCTION: Generate NEW secrets before deploying (don't use example values!)

PREMIUM_DAILY_LIMIT=50

# ── Git Configuration (for auto-updates) ─────────────────
# GitHub repository URL (for auto-update script)
GIT_REPO_URL=https://github.com/yourusername/NoteMind.git
GIT_BRANCH=main

# ── Backup Settings ──────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=/opt/notemind/backups
BACKUP_RETENTION_DAYS=30
