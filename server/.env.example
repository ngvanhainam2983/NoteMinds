# Qwen3 API Configuration
# If using Azure-hosted Qwen3 or any OpenAI-compatible endpoint
QWEN_API_BASE_URL=https://your-azure-endpoint.openai.azure.com/v1
QWEN_API_KEY=your-api-key-here
QWEN_MODEL=qwen3

# Alternative: Use local Qwen3 via Ollama
# QWEN_API_BASE_URL=http://localhost:11434/v1
# QWEN_API_KEY=ollama
# QWEN_MODEL=qwen3

# Server
PORT=3001
