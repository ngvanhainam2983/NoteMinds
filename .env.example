# ============================================================
#  NoteMind Environment Configuration Template
#
#  Copy this file to .env and fill in your actual values
# ============================================================

# ── Server Configuration ──────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database Configuration ────────────────────────────────
# (If using database connection string)
DATABASE_URL=

# ── API Keys ──────────────────────────────────────────────
# Qwen API Key (for AI processing)
QWEN_API_KEY=your_qwen_api_key_here

# ── JWT Secret ────────────────────────────────────────────
# Used for signing authentication tokens
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ── Encryption Configuration ──────────────────────────────
# IMPORTANT: Generate a secure 32-character hex string for encryption
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key is used to encrypt/decrypt all API requests and responses
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_change_this

# ── Rate Limiting ─────────────────────────────────────────
GUEST_DAILY_LIMIT=5
PREMIUM_DAILY_LIMIT=50

# ── Deployment Settings ──────────────────────────────────
DOMAIN=your-domain.com
ADMIN_EMAIL=admin@your-domain.com

# ── Git Configuration (for auto-updates) ─────────────────
# GitHub repository URL (for auto-update script)
GIT_REPO_URL=https://github.com/yourusername/NoteMind.git
GIT_BRANCH=main

# ── Backup Settings ──────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=/opt/notemind/backups
BACKUP_RETENTION_DAYS=30
