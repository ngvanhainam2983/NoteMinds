# ============================================================
#  NoteMind - AI-Powered Study Assistant
#  Environment Configuration Template (SINGLE ROOT FILE)
#
#  Copy this file to .env at repository root and fill values.
# ============================================================

# ────────────────────────────────────────────────────────
#  🚀 SERVER CONFIGURATION
# ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ────────────────────────────────────────────────────────
#  🤖 AI MODEL CONFIGURATION
#
#  Option A: DashScope (Recommended - Cloud-based)
# ────────────────────────────────────────────────────────
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-your-dashscope-api-key-here
QWEN_MODEL=qwen3-max

# ────────────────────────────────────────────────────────
#  🤖 OLLAMA (Local/Free Alternative)
#  Uncomment these lines and comment out DashScope above
# ────────────────────────────────────────────────────────
# QWEN_API_BASE_URL=http://localhost:11434/v1
# QWEN_API_KEY=ollama
# QWEN_MODEL=qwen3

# ────────────────────────────────────────────────────────
#  🔐 AUTHENTICATION & SECURITY
# ────────────────────────────────────────────────────────
# JWT secret for signing tokens (required, min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-key-min-32-characters-long

# Cloudflare Turnstile secret (required in production)
TURNSTILE_SECRET=your-turnstile-secret

# CORS whitelist (required for production split-domain)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ────────────────────────────────────────────────────────
#  💾 DATABASE CONFIGURATION
# ────────────────────────────────────────────────────────
# Keep SQLite path for current architecture
DATABASE_PATH=./data/notemind.db

# ────────────────────────────────────────────────────────
#  📋 PLAN QUOTAS & RATE LIMITING
# ────────────────────────────────────────────────────────
GUEST_DAILY_LIMIT=5
GUEST_CHAT_LIMIT=10
PREMIUM_DAILY_LIMIT=50

# API rate limit (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────
#  📧 EMAIL CONFIGURATION (OPTIONAL)
# ────────────────────────────────────────────────────────
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=NoteMind

# ────────────────────────────────────────────────────────
#  🌐 DOMAIN & DEPLOYMENT (SPLIT DOMAIN)
# ────────────────────────────────────────────────────────
# Root domain without protocol
DOMAIN=yourdomain.com

# Frontend URL (used by server, email links, passkey RP)
FRONTEND_URL=https://yourdomain.com

# API domain used for share links and callbacks
API_DOMAIN=https://api.yourdomain.com

# Client-side API override (Vite reads this from root .env)
# IMPORTANT: VITE_* vars are public in browser bundle
VITE_API_URL=https://api.yourdomain.com

# ────────────────────────────────────────────────────────
#  📊 LOGGING & MONITORING
# ────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ────────────────────────────────────────────────────────
#  🔍 ADMIN & APP SETTINGS
# ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@notemind.app
ADMIN_PASSWORD=ChangeMe123!

# Max upload file size (bytes)
MAX_FILE_SIZE=52428800

# Session timeout (minutes)
SESSION_TIMEOUT=1440

# ── Git Configuration (optional for auto-update scripts) ──
GIT_REPO_URL=https://github.com/yourusername/NoteMind.git
GIT_BRANCH=main

# ── Backup Settings (optional) ───────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=/opt/notemind/backups
BACKUP_RETENTION_DAYS=30

# ────────────────────────────────────────────────────────
#  📝 NOTES
# ────────────────────────────────────────────────────────
# ✅ Required for production:
#    - NODE_ENV=production
#    - JWT_SECRET
#    - QWEN_API_KEY (or Ollama settings)
#    - TURNSTILE_SECRET
#    - ALLOWED_ORIGINS
#    - FRONTEND_URL
#    - API_DOMAIN
#
# ⚠️ Never commit real .env to Git.
# ⚠️ Do not put secrets in VITE_* variables.
# ⚠️ This project now supports a single root .env file only.
